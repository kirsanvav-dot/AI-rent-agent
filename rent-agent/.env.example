# ── Сервер ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Демо-режим: только для разработки/CI; в production ВСЕГДА false.
# При DEMO_MODE=true Авито-запросы логируются, но не отправляются.
# Запуск с DEMO_MODE=true в NODE_ENV=production вызывает console.warn.
DEMO_MODE=false

# ── Notion CRM ──────────────────────────────────────────
# Integration token: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID базы данных (32 символа без дефисов)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenRouter (LLM) ────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
# Используется как заголовки HTTP-Referer / X-Title в запросах к OpenRouter
OPENROUTER_SITE_URL=https://example.com
OPENROUTER_APP_NAME=Rental AI Agent

# ── Telegram Bot ────────────────────────────────────────
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# chat_id владельца, куда отправляются уведомления о новых бронях
TELEGRAM_OWNER_CHAT_ID=123456789
# Исходящие запросы Bot API (sendMessage, answerCallbackQuery). Не влияет на входящий webhook.
# На RU-сервере без прямого доступа к Telegram: локальный Xray mixed inbound, например:
# TELEGRAM_PROXY=socks5://127.0.0.1:10808
# Локально / без блокировки — оставьте пустым или закомментируйте.
TELEGRAM_PROXY=

# ── Авито (STR API + Messenger) ─────────────────────────
# https://developers.avito.ru
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
# user_id рекламного аккаунта в Авито
AVITO_USER_ID=

# ── RealtyCalendar ──────────────────────────────────────
# Опциональный секрет для проверки подписи входящих вебхуков
# (верификация зарезервирована для будущей реализации, вне текущего скоупа)
REALTYCALENDAR_WEBHOOK_SECRET=

# ── RealtyCalendar (исходящий API) ──────────────────────
# Базовый URL RC REST API (например: https://realtycalendar.ru/api/v2)
REALTYCALENDAR_API_URL=https://realtycalendar.ru/api/v2
# Токен авторизации для исходящих запросов к RC API (Bearer или API-ключ)
REALTYCALENDAR_API_TOKEN=
# ID объекта в RealtyCalendar (нужен для blockDates; найти в кабинете RC → Объекты)
REALTYCALENDAR_OBJECT_ID=
